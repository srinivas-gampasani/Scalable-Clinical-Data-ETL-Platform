{
  "expectation_suite_name": "clinical_etl_patient_suite",
  "data_asset_type": null,
  "meta": {
    "great_expectations_version": "0.18.8",
    "created_by": "srinivas.gampasani",
    "created_at": "2024-01-01T00:00:00Z",
    "description": "Validation suite for clinical patient demographics"
  },
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "patient_id" },
      "meta": { "notes": "Primary key must exist" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "patient_id", "mostly": 1.0 },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "patient_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "mrn", "mostly": 1.0 },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "mrn" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "gender",
        "value_set": ["MALE", "FEMALE", "OTHER", "UNKNOWN"],
        "mostly": 0.999
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "dob", "mostly": 0.99 },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "age_years",
        "min_value": 0,
        "max_value": 130,
        "mostly": 0.999
      },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "insurance_type", "mostly": 0.99 },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "insurance_type",
        "value_set": ["MEDICARE", "MEDICAID", "BCBS", "AETNA", "UNITED", "CIGNA", "HUMANA", "SELF_PAY"],
        "mostly": 0.99
      },
      "meta": {}
    }
  ]
}
