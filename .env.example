# ─────────────────────────────────────────────────────────────────────────────
# Clinical ETL Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Pipeline Mode ─────────────────────────────────────────────────────────────
# Set to "true" for demo mode (synthetic data, SQLite). "false" for production.
DEMO_MODE=true
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO

# ── Snowflake (Production) ────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=clinical_etl_svc
SNOWFLAKE_PASSWORD=your_secure_password
SNOWFLAKE_DATABASE=CLINICAL_DW
SNOWFLAKE_WAREHOUSE=CLINICAL_WH
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=CLINICAL_ETL_ROLE

# ── Source System: EHR (FHIR R4 API) ─────────────────────────────────────────
EHR_BASE_URL=https://ehr.hospital.internal/fhir/R4
EHR_API_KEY=your_ehr_api_key

# ── Source System: Lab (SFTP) ─────────────────────────────────────────────────
LAB_SFTP_HOST=lab-sftp.hospital.internal
LAB_SFTP_USER=lab_etl_svc
LAB_SFTP_PASS=your_lab_sftp_password

# ── Source System: Billing (Database) ─────────────────────────────────────────
BILLING_DB_URL=postgresql+psycopg2://billing_ro:pass@billing-db.internal/billing

# ── Source System: Scheduling (REST API) ──────────────────────────────────────
SCHEDULING_URL=https://scheduling.hospital.internal/api/v2

# ── Source System: Pharmacy (SFTP) ────────────────────────────────────────────
PHARMACY_HOST=pharmacy-sftp.hospital.internal

# ── Source System: Radiology (REST API) ───────────────────────────────────────
RADIOLOGY_URL=https://pacs.hospital.internal/api

# ── Source System: ICU Monitors (Kafka) ───────────────────────────────────────
KAFKA_SERVERS=kafka-broker-01.hospital.internal:9092,kafka-broker-02.hospital.internal:9092

# ── Source System: HR (Database) ──────────────────────────────────────────────
HR_DB_URL=postgresql+psycopg2://hr_ro:pass@hr-db.internal/hrms

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ── Alerting ──────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=clinical-etl-alerts@hospital.org

# ── AWS (for S3 staging) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=clinical-etl-staging
